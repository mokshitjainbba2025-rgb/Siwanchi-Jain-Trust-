rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "mokshit.jain.bba2025@atlasskilltech.university" ||
        request.auth.token.email == "kamal.bhandari@yahoo.com"
      );
    }

    // Slideshow Images
    match /slideshow_images/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Gallery Items
    match /gallery_items/{galleryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Room Categories
    match /room_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Room Bookings
    match /room_bookings/{bookingId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Palace Bookings
    match /palace_bookings/{bookingId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Donations
    match /donations/{donationId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Contributors / Donor Wall
    match /contributors/{contribId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Volunteers
    match /volunteers/{volId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Members
    match /members/{memberId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }
  }
}
